.sp-card h3{font-size:1.05rem;font-weight:700;margin-bottom:10px;color:#e8f4f0}
.sp-card p{font-size:.84rem;color:rgba(232,244,240,.42);line-height:1.7;margin-bottom:24px}
.bank-display{
