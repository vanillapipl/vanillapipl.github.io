}
.faq-a.open{max-height:400px;padding:0 24px 22px}

/* ── STATUS ── */
#status{background:transparent}
.status-wrap{margin-top:48px;max-width:680px}
.status-badge{
  display:inline-flex;align-items:center;gap:12px;
  background:rgba(52,211,153,.06);
  border:1px solid rgba(52,211,153,.2);
  border-radius:14px;padding:18px 26px;
  margin-bottom:24px;
}
.status-dot{
  width:10px;height:10px;border-radius:50%;
  background:#22c55e;
  box-shadow:0 0 0 0 rgba(34,197,94,.5);
  animation:sdot 2s ease-in-out infinite;
  flex-shrink:0;
}
@keyframes sdot{
  0%{box-shadow:0 0 0 0 rgba(34,197,94,.6)}
  70%{box-shadow:0 0 0 9px rgba(34,197,94,0)}
  100%{box-shadow:0 0 0 0 rgba(34,197,94,0)}
}
.status-info{display:flex;flex-direction:column;gap:3px}
.status-label{font-size:.7rem;font-weight:700;color:rgba(232,244,240,.3);text-transform:uppercase;letter-spacing:.08em}
.status-text{font-size:.96rem;font-weight:600;color:#e8f4f0}
.status-link-card{
  display:flex;align-items:center;justify-content:space-between;gap:20px;
  background:rgba(255,255,255,.02);
  border:1px solid rgba(52,211,153,.12);
  border-radius:20px;padding:28px 34px;
  text-decoration:none;color:inherit;
  transition:all .3s;
}
.status-link-card:hover{border-color:rgba(52,211,153,.3);transform:translateY(-3px);box-shadow:0 12px 40px rgba(0,0,0,.4)}
.slc-left{display:flex;align-items:center;gap:18px}
.slc-ico{
  width:52px;height:52px;border-radius:14px;flex-shrink:0;
  background:linear-gradient(135deg,rgba(16,185,129,.2),rgba(5,150,105,.08));
  border:1px solid rgba(52,211,153,.25);
  display:flex;align-items:center;justify-content:center;font-size:1.5rem;
}
.slc-title{font-size:1rem;font-weight:700;margin-bottom:3px;color:#e8f4f0}
.slc-sub{font-size:.8rem;color:rgba(232,244,240,.38)}
.slc-arrow{font-size:1.2rem;color:rgba(232,244,240,.18);transition:.3s}
.status-link-card:hover .slc-arrow{transform:translate(4px,-4px);color:#34d399}

/* ── RECRUIT ── */
#recruit{background:transparent}
.recruit-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:52px;max-width:900px}
.rc-card{
  position:relative;overflow:hidden;
  border-radius:24px;padding:36px;
  display:flex;flex-direction:column;gap:0;
  transition:transform .35s cubic-bezier(.16,1,.3,1),box-shadow .35s;
}
.rc-card:hover{transform:translateY(-8px)}
.rc-card.mod{
  background:linear-gradient(145deg,rgba(16,185,129,.1) 0%,rgba(16,185,129,.04) 100%);
  border:1px solid rgba(16,185,129,.22);
  box-shadow:0 0 40px rgba(16,185,129,.06);
}
.rc-card.mod:hover{box-shadow:0 24px 64px rgba(0,0,0,.5),0 0 40px rgba(16,185,129,.12)}
.rc-card.media{
  background:linear-gradient(145deg,rgba(167,139,250,.1) 0%,rgba(139,92,246,.04) 100%);
  border:1px solid rgba(167,139,250,.22);
  box-shadow:0 0 40px rgba(167,139,250,.06);
}
.rc-card.media:hover{box-shadow:0 24px 64px rgba(0,0,0,.5),0 0 40px rgba(167,139,250,.12)}
.rc-header{position:relative;z-index:1;display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:24px}
.rc-icon{
  width:60px;height:60px;border-radius:18px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;font-size:1.8rem;
  border:1px solid rgba(255,255,255,.08);
}
.rc-card.mod .rc-icon{background:linear-gradient(135deg,rgba(16,185,129,.25),rgba(16,185,129,.1))}
.rc-card.media .rc-icon{background:linear-gradient(135deg,rgba(167,139,250,.25),rgba(139,92,246,.1))}
.rc-open-badge{
  font-size:.66rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;
  background:rgba(16,185,129,.12);color:#34d399;
  border:1px solid rgba(16,185,129,.25);
  border-radius:8px;padding:4px 10px;
}
.rc-title{position:relative;z-index:1;font-size:1.5rem;font-weight:800;letter-spacing:-.03em;color:#e8f4f0;margin-bottom:10px}
.rc-sub{position:relative;z-index:1;font-size:.87rem;color:rgba(232,244,240,.45);line-height:1.7;margin-bottom:24px}
.rc-reqs{position:relative;z-index:1;display:flex;flex-direction:column;gap:8px;margin-bottom:32px}
.rc-req{display:flex;align-items:center;gap:10px;font-size:.83rem;color:rgba(232,244,240,.5)}
.rc-req::before{content:'';width:5px;height:5px;border-radius:50%;background:rgba(52,211,153,.6);flex-shrink:0}
.rc-req.media-req::before{background:rgba(167,139,250,.6)}
.rc-btn{
  position:relative;z-index:1;
  display:inline-flex;align-items:center;justify-content:center;gap:8px;
  padding:14px 20px;border-radius:14px;font-family:'Outfit',sans-serif;
  font-size:.9rem;font-weight:700;text-decoration:none;
  transition:all .25s;
}
.rc-btn-mod{background:linear-gradient(135deg,rgba(16,185,129,.18),rgba(16,185,129,.08));border:1px solid rgba(16,185,129,.3);color:#34d399}
.rc-btn-mod:hover{background:linear-gradient(135deg,rgba(16,185,129,.28),rgba(16,185,129,.14));transform:translateY(-2px)}
.rc-btn-media{background:linear-gradient(135deg,rgba(167,139,250,.18),rgba(139,92,246,.08));border:1px solid rgba(167,139,250,.3);color:#a78bfa}
.rc-btn-media:hover{background:linear-gradient(135deg,rgba(167,139,250,.28),rgba(139,92,246,.14));transform:translateY(-2px)}
.rc-deco{position:absolute;bottom:-20px;right:-10px;font-size:5rem;opacity:.04;pointer-events:none;z-index:0;user-select:none}

/* ── BOTTOM ACTIONS ── */
.bottom-actions{
  position:relative;z-index:1;
  padding:60px 48px;
  background:rgba(52,211,153,.02);
  border-top:1px solid rgba(52,211,153,.07);
}
.ba-title{
  font-size:.72rem;font-weight:700;color:rgba(232,244,240,.3);
  text-transform:uppercase;letter-spacing:.1em;margin-bottom:20px;
  max-width:1100px;margin-left:auto;margin-right:auto;
}
.ba-cards{display:flex;gap:14px;flex-wrap:wrap;max-width:1100px;margin:0 auto}
.ba-card{
  display:flex;align-items:center;gap:14px;
  border-radius:16px;padding:18px 24px;
  text-decoration:none;color:inherit;
  transition:all .2s;border:1px solid;
}
.ba-card.appeal{background:rgba(52,211,153,.04);border-color:rgba(52,211,153,.15)}
.ba-card.appeal:hover{background:rgba(52,211,153,.08);border-color:rgba(52,211,153,.3);transform:translateY(-2px)}
.ba-card.unban{background:rgba(251,191,36,.04);border-color:rgba(251,191,36,.15)}
.ba-card.unban:hover{background:rgba(251,191,36,.08);border-color:rgba(251,191,36,.3);transform:translateY(-2px)}
.ba-ico{font-size:1.4rem}
.ba-info{display:flex;flex-direction:column;gap:3px}
.ba-info strong{font-size:.9rem;font-weight:700;color:#e8f4f0}
.ba-info span{font-size:.78rem;color:rgba(232,244,240,.35)}

/* ── FOOTER ── */
footer{
  position:relative;z-index:1;
  border-top:1px solid rgba(52,211,153,.08);
  padding:60px 48px;
}
.footer-inner{max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:28px}
.footer-brand .f-logo{font-family:'JetBrains Mono',monospace;font-size:1.1rem;font-weight:700;color:#34d399;margin-bottom:5px}
.footer-brand .f-tag{font-size:.8rem;color:rgba(232,244,240,.22)}
.footer-nav{display:flex;gap:22px;flex-wrap:wrap}
.footer-nav a{font-size:.8rem;color:rgba(232,244,240,.28);text-decoration:none;transition:.15s}
.footer-nav a:hover{color:#34d399}
.footer-copy{font-size:.77rem;color:rgba(232,244,240,.18)}

/* ── REVEAL ── */
.rv{opacity:0;transform:translateY(32px);transition:opacity .7s cubic-bezier(.16,1,.3,1),transform .7s cubic-bezier(.16,1,.3,1)}
.rv.in{opacity:1;transform:translateY(0)}
.rv2{opacity:0;transform:translateY(32px);transition:opacity .7s .13s cubic-bezier(.16,1,.3,1),transform .7s .13s cubic-bezier(.16,1,.3,1)}
.rv2.in{opacity:1;transform:translateY(0)}
.rv3{opacity:0;transform:translateY(32px);transition:opacity .7s .26s cubic-bezier(.16,1,.3,1),transform .7s .26s cubic-bezier(.16,1,.3,1)}
.rv3.in{opacity:1;transform:translateY(0)}

/* ── FLOATING PARTICLES ── */
.particle{
  position:fixed;border-radius:50%;pointer-events:none;z-index:0;
  background:rgba(52,211,153,.15);
  animation:float-up linear infinite;
  transition:opacity .4s;
}
@keyframes float-up{
  0%{transform:translateY(0) scale(1);opacity:0}
  10%{opacity:.6}
  90%{opacity:.2}
  100%{transform:translateY(-100vh) scale(.5);opacity:0}
}

/* ── NAV TOOLS ── */
.nav-tools{display:flex;align-items:center;gap:8px;margin-left:8px}
.fx-btn{
  width:34px;height:34px;border-radius:9px;
  background:rgba(52,211,153,.08);border:1px solid rgba(52,211,153,.18);
  color:rgba(232,244,240,.5);font-size:.85rem;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  transition:all .2s;flex-shrink:0;
