<script>
// ── CURSOR ──
(function(){
  var cur=document.getElementById('cursor');
  var ring=document.getElementById('cursor-ring');
  var mx=window.innerWidth/2,my=window.innerHeight/2;
  var rx=mx,ry=my,tick=0;
  document.addEventListener('mousemove',function(e){
    mx=e.clientX;my=e.clientY;
    cur.style.left=mx+'px';cur.style.top=my+'px';
    tick++;
    if(tick%2===0&&!document.body.classList.contains('fx-off')){
      var s=document.createElement('div');
      s.className='cursor-spark';
      var sz=Math.random()*5+2;
      var dx=(Math.random()-.5)*44;
      var dy=(Math.random()-.5)*44-12;
      s.style.cssText='width:'+sz+'px;height:'+sz+'px;left:'+mx+'px;top:'+my+'px;border-radius:'+(Math.random()>.6?'50%':'2px');
      s.style.setProperty('--dx',dx+'px');
      s.style.setProperty('--dy',dy+'px');
      s.style.setProperty('--r',Math.random()*360+'deg');
      document.body.appendChild(s);
      setTimeout(function(){if(s.parentNode)s.parentNode.removeChild(s)},700);
    }
  });
  (function animR(){
    rx+=(mx-rx)*.1;ry+=(my-ry)*.1;
    ring.style.left=rx+'px';ring.style.top=ry+'px';
    requestAnimationFrame(animR);
  })();
})();

// ── PARTICLES ──
(function(){
  for(var i=0;i<16;i++){
    var p=document.createElement('div');
    p.className='particle';
    var s=Math.random()*4+2;
    p.style.cssText='width:'+s+'px;height:'+s+'px;left:'+Math.random()*100+'%;bottom:-10px;animation-duration:'+(Math.random()*18+14)+'s;animation-delay:-'+(Math.random()*20)+'s';
    document.body.appendChild(p);
  }
})();

// ── FX TOGGLE ──
var fxOn=localStorage.getItem('vp-fx')!=='off';
function applyFx(){
  var btn=document.getElementById('fxBtn');
  if(fxOn){document.body.classList.remove('fx-off');btn.textContent='✦';btn.classList.remove('off')}
  else{document.body.classList.add('fx-off');btn.textContent='✧';btn.classList.add('off')}
}
function toggleFx(){fxOn=!fxOn;localStorage.setItem('vp-fx',fxOn?'on':'off');applyFx()}
applyFx();

// ── THEME ──
var THEMES={green:'#34d399',blue:'#38bdf8',purple:'#a78bfa',red:'#f87171',orange:'#fb923c',yellow:'#fbbf24',pink:'#f472b6',cyan:'#22d3ee'};
var theme=localStorage.getItem('vp-theme')||'green';
function applyTheme(t){
  document.body.removeAttribute('data-theme');
  if(t!=='green')document.body.setAttribute('data-theme',t);
  var dot=document.getElementById('themeDot');
  dot.style.background=THEMES[t];dot.style.boxShadow='0 0 8px '+THEMES[t];
  document.querySelectorAll('.tp-opt').forEach(function(el){el.classList.toggle('active',el.dataset.theme===t)});
}
function setTheme(t){theme=t;localStorage.setItem('vp-theme',t);applyTheme(t);document.getElementById('themePicker').classList.remove('open')}
function toggleThemePicker(){document.getElementById('themePicker').classList.toggle('open')}
document.addEventListener('click',function(e){
  var w=document.querySelector('.theme-wrap');
  if(w&&!w.contains(e.target))document.getElementById('themePicker').classList.remove('open');
});
applyTheme(theme);

// ── SEASON PROGRESS ──
(function(){
  var start=new Date('2026-03-25');
  var end=new Date('2026-06-01');
  var now=new Date();
  var pct=Math.min(100,Math.max(0,Math.round((now-start)/(end-start)*100)));
  var bar=document.getElementById('s1bar');
  var lbl=document.getElementById('s1pct');
  if(bar)setTimeout(function(){bar.style.width=pct+'%'},200);
  if(lbl)lbl.textContent=pct+'%';
})();

// ── COUNTDOWN ──
function updateCd(){
  var d=new Date('2026-06-01')-new Date();
  var el=document.getElementById('countdown');
  if(!el)return;
  if(d<=0){el.textContent='Уже здесь!';return}
  var days=Math.floor(d/864e5);
  var h=Math.floor((d%864e5)/36e5);
  var m=Math.floor((d%36e5)/6e4);
  el.textContent=days+'д '+h+'ч '+m+'м';
}
updateCd();setInterval(updateCd,6e4);

// ── FAQ ──
function toggleFaq(item){
  var open=item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(function(i){
    i.classList.remove('open');i.querySelector('.faq-a').classList.remove('open');
  });
  if(!open){item.classList.add('open');item.querySelector('.faq-a').classList.add('open')}
}

// ── COPY ──
function doCopy(txt,cb){
  if(navigator.clipboard&&location.protocol==='https:'){navigator.clipboard.writeText(txt).then(cb).catch(function(){fb(txt,cb)})}
  else{fb(txt,cb)}
}
function fb(txt,cb){
  var t=document.createElement('textarea');t.value=txt;
  t.style.cssText='position:fixed;left:-9999px;opacity:0';
  document.body.appendChild(t);t.focus();t.select();
  try{document.execCommand('copy');cb()}catch(e){}
  document.body.removeChild(t);
}
function copyIP(){
  doCopy('vanillapipl.joinserver.xyz',function(){
    document.getElementById('ci').textContent='✔';
    document.getElementById('ct').textContent='Скопировано!';
    setTimeout(function(){document.getElementById('ci').textContent='📋';document.getElementById('ct').textContent='Скопировать IP'},2500);
  });
}
