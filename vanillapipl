/* ── SOCIALS ── */
#social{background:rgba(52,211,153,.02);border-top:1px solid rgba(52,211,153,.07)}
.soc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:52px;max-width:780px}
.soc-card{
