<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VanillaPipl — Minecraft SMP-E</title>
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='16' fill='%230a1628'/%3E%3Crect x='18' y='18' width='28' height='28' fill='%2334d399'/%3E%3Crect x='54' y='18' width='28' height='28' fill='%2310b981'/%3E%3Crect x='18' y='54' width='28' height='28' fill='%236ee7b7'/%3E%3Crect x='54' y='54' width='28' height='28' fill='%2334d399'/%3E%3Crect x='18' y='68' width='64' height='14' fill='%23713f12'/%3E%3C/svg%3E">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  background:#060d1a;
  color:#e8f4f0;
  font-family:'Outfit',sans-serif;
  line-height:1.6;
  overflow-x:hidden;
  cursor:none;
}
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:#060d1a}
::-webkit-scrollbar-thumb{background:#34d399;border-radius:3px}

/* ── CUSTOM CURSOR ── */
#cursor{
  position:fixed;width:12px;height:12px;border-radius:2px;
  background:var(--c1,#34d399);pointer-events:none;z-index:99999;
  transform:translate(-50%,-50%) rotate(45deg);
  box-shadow:0 0 10px rgba(52,211,153,.7);
}
#cursor-ring{
  position:fixed;width:28px;height:28px;border-radius:50%;
  border:1.5px solid rgba(52,211,153,.4);pointer-events:none;z-index:99998;
  transform:translate(-50%,-50%);
}
.cursor-spark{
  position:fixed;border-radius:2px;pointer-events:none;z-index:99997;
  background:var(--c1,#34d399);
  animation:spark-fade .7s ease-out forwards;
}
@keyframes spark-fade{
  0%{opacity:.9;transform:translate(-50%,-50%) scale(1) rotate(var(--r,0deg))}
  100%{opacity:0;transform:translate(calc(-50% + var(--dx,0px)),calc(-50% + var(--dy,-20px))) scale(0) rotate(var(--r,0deg))}
}
body.fx-off #cursor-ring{opacity:0}

/* ── BACKGROUND ── */
.bg-main{
  position:fixed;inset:0;z-index:0;pointer-events:none;
  background:
    radial-gradient(ellipse 70% 50% at 20% 20%, rgba(16,185,129,.07) 0%, transparent 60%),
    radial-gradient(ellipse 60% 60% at 80% 70%, rgba(52,211,153,.05) 0%, transparent 55%),
    radial-gradient(ellipse 40% 40% at 50% 50%, rgba(6,182,212,.04) 0%, transparent 50%);
  transition:opacity .4s;
}
.bg-stars{
  position:fixed;inset:0;z-index:0;pointer-events:none;
  background-image:
    radial-gradient(1px 1px at 20% 30%, rgba(52,211,153,.4) 0%, transparent 100%),
    radial-gradient(1px 1px at 80% 10%, rgba(52,211,153,.3) 0%, transparent 100%),
    radial-gradient(1px 1px at 60% 70%, rgba(110,231,183,.3) 0%, transparent 100%),
    radial-gradient(1px 1px at 10% 80%, rgba(52,211,153,.2) 0%, transparent 100%),
    radial-gradient(1px 1px at 90% 50%, rgba(110,231,183,.25) 0%, transparent 100%),
    radial-gradient(2px 2px at 45% 15%, rgba(52,211,153,.5) 0%, transparent 100%),
    radial-gradient(1px 1px at 70% 90%, rgba(110,231,183,.2) 0%, transparent 100%),
    radial-gradient(2px 2px at 30% 60%, rgba(52,211,153,.35) 0%, transparent 100%);
  transition:opacity .4s;
}
body.fx-off .bg-main,
body.fx-off .bg-stars,
body.fx-off .particle{opacity:0;pointer-events:none}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  height:68px;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 48px;
  background:rgba(6,13,26,.8);
  backdrop-filter:blur(28px);
  border-bottom:1px solid rgba(52,211,153,.1);
}
.logo{
  font-family:'JetBrains Mono',monospace;
  font-size:1.1rem;font-weight:700;
  color:#34d399;
  display:flex;align-items:center;gap:12px;
  text-decoration:none;
  letter-spacing:.02em;
}
.logo-icon{
  width:34px;height:34px;border-radius:8px;
  background:linear-gradient(135deg,#059669,#10b981);
  display:flex;align-items:center;justify-content:center;
  font-size:1rem;
  box-shadow:0 0 16px rgba(16,185,129,.4);
  animation:glow-pulse 3s ease-in-out infinite;
}
@keyframes glow-pulse{
  0%,100%{box-shadow:0 0 16px rgba(16,185,129,.4)}
  50%{box-shadow:0 0 28px rgba(52,211,153,.7)}
}
.nav-links{display:flex;gap:4px;align-items:center}
.nav-links a{
  color:rgba(232,244,240,.45);
  text-decoration:none;font-size:.84rem;font-weight:500;
  padding:7px 15px;border-radius:8px;
  transition:color .15s,background .15s;
  letter-spacing:.01em;
}
.nav-links a:hover{color:#e8f4f0;background:rgba(52,211,153,.08)}
.nav-links a.hl{color:var(--c1,#34d399);font-weight:600}
.burger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:8px}
.burger span{width:22px;height:2px;background:rgba(52,211,153,.6);border-radius:1px;transition:.25s}
.mob{
  display:none;position:fixed;top:68px;left:0;right:0;z-index:99;
  background:rgba(6,13,26,.97);backdrop-filter:blur(24px);
  border-bottom:1px solid rgba(52,211,153,.1);
  padding:12px 20px;flex-direction:column;gap:2px;
}
.mob.open{display:flex}
.mob a{color:rgba(232,244,240,.55);text-decoration:none;font-size:.9rem;font-weight:500;padding:12px 16px;border-radius:8px;transition:.15s}
.mob a:hover{color:#e8f4f0;background:rgba(52,211,153,.08)}
.mob a.hl{color:var(--c1,#34d399)}

/* ── NEWS PAGES ── */
.npage{display:none;position:fixed;inset:0;z-index:200;background:#060d1a;overflow-y:auto;padding-top:68px}
.npage.open{display:block}
.npage-wrap{max-width:720px;margin:0 auto;padding:48px 24px 80px}
.back-btn{
  display:inline-flex;align-items:center;gap:8px;
  color:rgba(52,211,153,.7);font-size:.85rem;
  padding:9px 18px;border-radius:10px;
  border:1px solid rgba(52,211,153,.2);
  background:rgba(52,211,153,.05);
  cursor:pointer;transition:.2s;margin-bottom:36px;font-family:'Outfit',sans-serif;
}
.back-btn:hover{color:#34d399;border-color:rgba(52,211,153,.4)}
.npage h1{font-size:clamp(1.6rem,4vw,2.2rem);font-weight:800;letter-spacing:-.03em;margin-bottom:10px;color:#e8f4f0}
.npage-date{font-size:.78rem;color:rgba(232,244,240,.3);font-family:'JetBrains Mono',monospace;margin-bottom:32px}
.npage-cover{height:200px;border-radius:20px;background:linear-gradient(135deg,#0a1e14,#0f2d1f);border:1px solid rgba(52,211,153,.15);display:flex;align-items:center;justify-content:center;font-size:4rem;margin-bottom:36px}
.npage p{color:rgba(232,244,240,.6);line-height:1.8;font-size:.93rem;margin-bottom:14px}
.npage h2{font-size:1.1rem;font-weight:700;color:#34d399;margin:24px 0 10px}
.npage ul{padding-left:20px;color:rgba(232,244,240,.6);line-height:1.8;font-size:.93rem;margin-bottom:14px}
.npage a{color:#34d399;text-decoration:none;border-bottom:1px solid rgba(52,211,153,.3)}
.npage a:hover{border-bottom-color:#34d399}

/* ── HERO ── */
#hero{
  position:relative;z-index:1;
  min-height:100vh;
  display:flex;align-items:center;justify-content:center;
  text-align:center;
  padding:120px 24px 80px;
}
.hero-wrap{max-width:800px;margin:0 auto}
.hero-banner{
  margin-bottom:28px;
  display:flex;align-items:center;justify-content:center;
}
.hero-banner img{
  max-width:min(520px,92vw);
  width:100%;
  filter:drop-shadow(0 0 40px rgba(52,211,153,.18)) drop-shadow(0 0 80px rgba(16,185,129,.08));
  animation:banner-float 6s ease-in-out infinite;
  image-rendering:pixelated;
}
@keyframes banner-float{
  0%,100%{transform:translateY(0)}
  50%{transform:translateY(-8px)}
}
.hero-badge{
  display:inline-flex;align-items:center;gap:10px;
  background:rgba(52,211,153,.08);
  border:1px solid rgba(52,211,153,.22);
  border-radius:100px;padding:8px 22px;
  font-size:.74rem;font-weight:700;
  color:#34d399;letter-spacing:.1em;text-transform:uppercase;
  margin-bottom:36px;
}
.badge-dot{
  width:7px;height:7px;border-radius:50%;
  background:#34d399;
  box-shadow:0 0 10px rgba(52,211,153,.8);
  animation:badge-ping 2s ease-in-out infinite;
}
@keyframes badge-ping{
  0%,100%{box-shadow:0 0 6px rgba(52,211,153,.6)}
  50%{box-shadow:0 0 18px rgba(52,211,153,1)}
}
.hero-title{
  font-size:clamp(3.8rem,12vw,7.5rem);
  font-weight:900;line-height:.92;
  letter-spacing:-.05em;
  margin-bottom:28px;
}
.hero-title .t1{color:#e8f4f0}
.hero-title .t2{
  background:linear-gradient(135deg,#34d399,#10b981,#059669);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.hero-desc{
  font-size:clamp(.95rem,2vw,1.15rem);
  color:rgba(232,244,240,.45);line-height:1.8;
  max-width:540px;margin:0 auto 52px;font-weight:400;
}
.hero-ip-block{
  display:inline-flex;align-items:center;gap:0;
  background:rgba(52,211,153,.06);
  border:1px solid rgba(52,211,153,.2);
  border-radius:16px;overflow:hidden;
  margin-bottom:44px;
}
.ip-label{
  padding:14px 18px;
  font-size:.7rem;font-weight:700;color:rgba(52,211,153,.6);
  text-transform:uppercase;letter-spacing:.08em;
  border-right:1px solid rgba(52,211,153,.12);
}
.ip-addr{
  padding:14px 22px;
  font-family:'JetBrains Mono',monospace;font-size:.95rem;font-weight:700;color:#34d399;
  border-right:1px solid rgba(52,211,153,.12);
  letter-spacing:.02em;
}
.ip-ver{
  padding:14px 18px;
  font-family:'JetBrains Mono',monospace;font-size:.78rem;color:rgba(232,244,240,.25);
}
.hero-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap}

/* ── BUTTONS ── */
.btn{
  display:inline-flex;align-items:center;gap:8px;
  font-family:'Outfit',sans-serif;font-size:.9rem;font-weight:600;
  padding:13px 26px;border-radius:12px;
  border:none;cursor:pointer;text-decoration:none;
  transition:all .2s;letter-spacing:.01em;
}
.btn-green{
  background:linear-gradient(135deg,#059669,#10b981);
  color:#fff;
  box-shadow:0 0 0 1px rgba(16,185,129,.5),0 8px 28px rgba(5,150,105,.4);
}
.btn-green:hover{
  box-shadow:0 0 0 1px rgba(52,211,153,.7),0 12px 40px rgba(16,185,129,.6);
  transform:translateY(-2px);
}
.btn-ghost{
  background:rgba(52,211,153,.06);color:rgba(232,244,240,.65);
  border:1px solid rgba(52,211,153,.2);
}
.btn-ghost:hover{
  background:rgba(52,211,153,.12);color:#e8f4f0;
  border-color:rgba(52,211,153,.38);transform:translateY(-2px);
}
.btn-sm{padding:9px 18px;font-size:.84rem;border-radius:9px}

/* ── SECTION ── */
.section{position:relative;z-index:1;padding:120px 48px}
.section-inner{max-width:1100px;margin:0 auto}
.sec-label{
  display:inline-flex;align-items:center;gap:10px;
  font-size:.7rem;font-weight:700;color:#34d399;
  letter-spacing:.12em;text-transform:uppercase;margin-bottom:18px;
}
.sec-label::before{content:'';width:24px;height:2px;background:rgba(52,211,153,.5);border-radius:1px}
.sec-title{
  font-size:clamp(2.2rem,4.5vw,3.2rem);font-weight:800;
  letter-spacing:-.04em;line-height:1.08;margin-bottom:18px;
}
.sec-sub{color:rgba(232,244,240,.42);font-size:.95rem;line-height:1.8;max-width:520px}

/* ── DIVIDER ── */
.div-line{
  position:relative;z-index:1;
  height:1px;max-width:1100px;margin:0 auto;
  background:linear-gradient(90deg,transparent,rgba(52,211,153,.15),transparent);
}

/* ── SEASON CARDS ── */
.seasons-grid{display:grid;grid-template-columns:1fr 1fr;gap:28px;margin-top:56px}
.season-card{
  border-radius:24px;padding:40px;
  position:relative;overflow:hidden;
  transition:transform .3s,box-shadow .3s;
}
.season-card:hover{transform:translateY(-6px)}
.season-card.current{
  background:linear-gradient(135deg,rgba(16,185,129,.12),rgba(52,211,153,.06));
  border:1px solid rgba(52,211,153,.28);
  box-shadow:0 0 60px rgba(16,185,129,.08),inset 0 1px 0 rgba(52,211,153,.1);
}
.season-card.current:hover{box-shadow:0 20px 60px rgba(0,0,0,.5),0 0 60px rgba(16,185,129,.12)}
.season-card.upcoming{
  background:linear-gradient(135deg,rgba(250,204,21,.06),rgba(251,191,36,.03));
  border:1px solid rgba(251,191,36,.2);
}
.season-card.upcoming:hover{box-shadow:0 20px 60px rgba(0,0,0,.5),0 0 40px rgba(251,191,36,.08)}
.season-card::before{
  content:'';position:absolute;
  width:200px;height:200px;border-radius:50%;
  top:-60px;right:-60px;pointer-events:none;
}
.season-card.current::before{background:radial-gradient(circle,rgba(52,211,153,.12),transparent 70%)}
.season-card.upcoming::before{background:radial-gradient(circle,rgba(251,191,36,.1),transparent 70%)}
.season-status{
  display:inline-flex;align-items:center;gap:7px;
  font-size:.68rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;
  border-radius:8px;padding:5px 12px;margin-bottom:22px;
}
.status-active{background:rgba(52,211,153,.12);color:#34d399;border:1px solid rgba(52,211,153,.25)}
.status-soon{background:rgba(251,191,36,.1);color:#fbbf24;border:1px solid rgba(251,191,36,.2)}
.s-dot{width:6px;height:6px;border-radius:50%;background:currentColor;animation:badge-ping 2s infinite}
.season-num{
  font-size:clamp(2.5rem,5vw,3.5rem);font-weight:900;letter-spacing:-.05em;margin-bottom:8px;
}
.season-card.current .season-num{
  background:linear-gradient(135deg,#34d399,#10b981);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.season-card.upcoming .season-num{
  background:linear-gradient(135deg,#fbbf24,#f59e0b);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.season-sub{font-size:1rem;font-weight:600;color:rgba(232,244,240,.7);margin-bottom:16px}
.season-info{font-size:.87rem;color:rgba(232,244,240,.42);line-height:1.7;margin-bottom:28px}
.season-meta{display:flex;flex-direction:column;gap:10px;margin-top:8px}
.smeta-row{display:flex;align-items:center;gap:12px;font-size:.82rem;color:rgba(232,244,240,.5)}
.smeta-icon{font-size:1rem}
.smeta-row strong{color:rgba(232,244,240,.8);font-weight:600}
.season-wipe{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2);
  border-radius:10px;padding:10px 16px;
  font-size:.82rem;font-weight:600;color:#f87171;
  margin-top:20px;
}

/* ── ABOUT PILLS ── */
.pills-row{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px;margin-top:48px}
.pill{
  display:flex;align-items:flex-start;gap:16px;
  background:rgba(52,211,153,.03);
  border:1px solid rgba(52,211,153,.1);
  border-radius:16px;padding:22px;
  transition:all .25s;
}
.pill:hover{background:rgba(52,211,153,.07);border-color:rgba(52,211,153,.22);transform:translateY(-3px)}
.pill-ico{
  width:42px;height:42px;border-radius:12px;flex-shrink:0;
  background:rgba(52,211,153,.1);
  border:1px solid rgba(52,211,153,.2);
  display:flex;align-items:center;justify-content:center;font-size:1.2rem;
}
.pill h4{font-size:.92rem;font-weight:700;margin-bottom:4px;color:#e8f4f0}
.pill p{font-size:.78rem;color:rgba(232,244,240,.4);line-height:1.5}

/* ── GUIDE ── */
#guide{background:rgba(52,211,153,.02);border-top:1px solid rgba(52,211,153,.08);border-bottom:1px solid rgba(52,211,153,.08)}
.guide-steps{display:flex;flex-direction:column;gap:0;margin-top:56px;max-width:820px}
.guide-step{
  display:flex;gap:32px;
  padding:32px 0;
  border-bottom:1px solid rgba(52,211,153,.07);
  position:relative;
}
.guide-step:last-child{border-bottom:none}
.step-left{display:flex;flex-direction:column;align-items:center;gap:0;flex-shrink:0;width:48px}
.step-num{
  width:48px;height:48px;border-radius:14px;flex-shrink:0;
  background:linear-gradient(135deg,rgba(5,150,105,.3),rgba(16,185,129,.15));
  border:1px solid rgba(52,211,153,.3);
  display:flex;align-items:center;justify-content:center;
  font-family:'JetBrains Mono',monospace;font-size:.9rem;font-weight:700;color:#34d399;
  position:relative;z-index:1;
}
.step-line{
  width:2px;flex:1;min-height:20px;
  background:linear-gradient(180deg,rgba(52,211,153,.2),rgba(52,211,153,.05));
  margin-top:8px;
}
.guide-step:last-child .step-line{display:none}
.step-body{flex:1;padding-top:10px}
.step-title{font-size:1.05rem;font-weight:700;color:#e8f4f0;margin-bottom:10px}
.step-desc{font-size:.87rem;color:rgba(232,244,240,.5);line-height:1.75}
.step-desc strong{color:#34d399;font-weight:600}
.step-tip{
  display:flex;align-items:flex-start;gap:10px;
  background:rgba(52,211,153,.06);
  border:1px solid rgba(52,211,153,.15);
  border-left:3px solid #34d399;
  border-radius:0 10px 10px 0;
  padding:14px 16px;margin-top:14px;
  font-size:.82rem;color:rgba(232,244,240,.55);line-height:1.6;
}
.step-tip .tip-icon{font-size:1rem;flex-shrink:0;margin-top:1px}
.death-chest-box{
  display:flex;gap:18px;
  background:linear-gradient(135deg,rgba(239,68,68,.08),rgba(220,38,38,.04));
  border:1px solid rgba(239,68,68,.22);
  border-radius:16px;padding:24px;margin-top:14px;
}
.death-ico{
  width:52px;height:52px;border-radius:14px;flex-shrink:0;
  background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.25);
  display:flex;align-items:center;justify-content:center;font-size:1.5rem;
}
.death-body h4{font-size:.95rem;font-weight:700;color:#f87171;margin-bottom:8px}
.death-body p{font-size:.83rem;color:rgba(232,244,240,.5);line-height:1.65}

/* ── NEWS ── */
#news{background:transparent}
.news-header{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:48px;flex-wrap:wrap;gap:16px}
.news-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.nc{
  background:rgba(255,255,255,.02);
  border:1px solid rgba(52,211,153,.1);
  border-radius:20px;overflow:hidden;
  display:flex;flex-direction:column;
  transition:all .3s;cursor:pointer;
}
.nc:hover{
  border-color:rgba(52,211,153,.3);
  transform:translateY(-6px);
  box-shadow:0 20px 60px rgba(0,0,0,.5),0 0 0 1px rgba(52,211,153,.1);
}
.nc-img{
  height:160px;position:relative;overflow:hidden;
  background:#071018;
  display:flex;align-items:center;justify-content:center;font-size:3rem;
}
.nc-img::after{
  content:'';position:absolute;inset:0;z-index:1;
  background:linear-gradient(0deg,rgba(6,13,26,.75) 0%,rgba(6,13,26,.1) 55%,transparent 100%);
  transition:opacity .35s;
}
.nc:hover .nc-img::after{opacity:.5}
.nc-img::before{
  content:'';position:absolute;
  top:0;left:-100%;width:60%;height:100%;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,.09),transparent);
  transition:left .55s ease;z-index:2;
}
.nc:hover .nc-img::before{left:150%}
.nc-img .nc-emoji{
  position:relative;z-index:3;
  transition:transform .45s cubic-bezier(.16,1,.3,1),filter .45s;
  display:block;
}
.nc:hover .nc-emoji{
  transform:scale(1.22) translateY(-4px);
  filter:drop-shadow(0 0 14px rgba(52,211,153,.6));
}
.nc-img-scan{
  position:absolute;inset:0;z-index:0;pointer-events:none;
  background-image:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,.06) 3px,rgba(0,0,0,.06) 4px);
}
