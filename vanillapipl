}
.team-desc{font-size:.8rem;color:rgba(232,244,240,.38);line-height:1.5}

/* ── FAQ ── */
#faq{background:transparent}
.faq-list{margin-top:52px;max-width:780px;display:flex;flex-direction:column;gap:10px}
.faq-item{
  background:rgba(255,255,255,.02);
  border:1px solid rgba(52,211,153,.1);
  border-radius:14px;overflow:hidden;
  transition:border-color .2s;
}
.faq-item.open{border-color:rgba(52,211,153,.28)}
.faq-q{
  display:flex;align-items:center;justify-content:space-between;gap:16px;
  padding:20px 24px;cursor:pointer;
  font-size:.94rem;font-weight:600;color:#e8f4f0;
  transition:background .2s;
}
.faq-q:hover{background:rgba(52,211,153,.04)}
.faq-icon{
  width:28px;height:28px;border-radius:8px;flex-shrink:0;
  background:rgba(52,211,153,.1);border:1px solid rgba(52,211,153,.2);
  display:flex;align-items:center;justify-content:center;
  font-size:.88rem;font-weight:700;color:#34d399;
